{
  "$schema": "https://opencode.ai/config.json",
  "permission": {},
  "lsp": true,
  "formatter": true,
  "model": "openrouter/deepseek/deepseek-v4-pro",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openrouter/moonshotai/kimi-k2.7-code"
    },
    "plan": {
      "mode": "primary",
      "model": "openrouter/z-ai/glm-5.2",
      "variant": "high"
    },
    "general": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-pro"
    },
    "explore": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "steps": 8,
      "permission": {
        "task": "deny"
      }
    },
    "scout": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "steps": 10,
      "permission": {
        "task": "deny"
      }
    },
    "compaction": {
      "mode": "primary",
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "summary": {
      "mode": "primary",
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "title": {
      "mode": "primary",
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "general-strong": {
      "mode": "subagent",
      "model": "openrouter/z-ai/glm-5.2",
      "variant": "max",
      "steps": 30
    },
    "frontier": {
      "mode": "subagent",
      "model": "openrouter/openai/gpt-5.6-sol",
      "steps": 32
    }
  }
}
